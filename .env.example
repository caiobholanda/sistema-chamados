# Porta do servidor (padrão 3000)
PORT=3000

# Segredo JWT — gere um valor aleatório forte (ex.: openssl rand -hex 32)
JWT_SECRET=troque-por-um-segredo-forte-aqui

# Credenciais do admin master inicial (criado apenas no primeiro boot)
ADMIN_MASTER_USER=admin
ADMIN_MASTER_PASS=TroqueEssaSenha123!
ADMIN_MASTER_NOME=Administrador Master

# Chave da API Anthropic — necessária para análise de equipamentos por IA
# Obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Chave de exportação de dados — obrigatória no boot (mínimo 16 chars, ex.: openssl rand -hex 32)
EXPORT_KEY=troque-por-uma-chave-forte-aqui

# Segredo compartilhado com o HubSistemas (SSO e rotas server-to-server)
SSO_SECRET=troque-por-um-segredo-forte-aqui

# Chaves VAPID para notificações push (gere com: npx web-push generate-vapid-keys)
# Se ausentes, são geradas no primeiro boot e salvas na tabela config (chave vapid_keys)
VAPID_PUBLIC_KEY=chave-publica-vapid-aqui
VAPID_PRIVATE_KEY=chave-privada-vapid-aqui

# E-mail de contato exigido pelo protocolo Web Push
VAPID_EMAIL=ti@exemplo.com.br
