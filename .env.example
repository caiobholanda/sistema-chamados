# Porta do servidor (padrão 3000)
PORT=3000

# Segredo JWT — gere um valor aleatório forte (ex.: openssl rand -hex 32)
JWT_SECRET=troque-por-um-segredo-forte-aqui

# Credenciais do admin master inicial (criado apenas no primeiro boot)
ADMIN_MASTER_USER=admin
ADMIN_MASTER_PASS=TroqueEssaSenha123!
ADMIN_MASTER_NOME=Administrador Master
